# Django Base Environment Settings
DEBUG=False
SECRET_KEY=your-django-production-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-production-domain.com

# PostgreSQL Connection Credentials
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Cloudinary CDN Integration Settings
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
DEFAULT_FROM_EMAIL=your-email-sender-identity@gmail.com

# Security Tokens Settings
JWT_SECRET_KEY=your-jwt-signing-secret-key
TOKEN_EXPIRY_DAYS=7
